# ============================================================
# Xperience — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase (required) ────────────────────────────────────
# Get these from your Supabase project > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Edge Functions (server-side secrets) ──────────
# Set these in Supabase Dashboard > Edge Functions > Secrets
# NOT prefixed with VITE_ — never exposed to the browser

ANTHROPIC_API_KEY=sk-ant-...         # Claude API key for AI generation
X_BEARER_TOKEN=AAAA...               # X API v2 Bearer Token for real trends (optional)

# ── Optional: X OAuth for account connections ──────────────
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_CALLBACK_URL=https://your-app.vercel.app/auth/callback
